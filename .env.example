# ── Required ────────────────────────────────────────────────────────────────
# Admin login for /admin — the user is created automatically on first boot.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me-please

# Canonical URL used for SEO / sitemap / receipts (defaults to https://fitizens.in).
NEXT_PUBLIC_SITE_URL=https://fitizens.in

# ── Storage (optional) ──────────────────────────────────────────────────────
# Where the SQLite DB + uploaded images live. Defaults to ./data locally and
# /data inside Docker (mount a volume there!).
# DATA_DIR=./data

# ── Email (optional — leads/receipts log to console until configured) ───────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Where lead/registration notifications go. Defaults to the trainer email set in /admin.
LEAD_TO_EMAIL=

# ── Razorpay (optional — pay buttons show "coming soon" until configured) ───
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Secret you set in the Razorpay dashboard when creating the webhook
# (point it at https://<your-domain>/api/payment/webhook, events:
#  payment.captured + payment.failed).
RAZORPAY_WEBHOOK_SECRET=

# ── Analytics (optional) ────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# ── Instagram feed (optional — shows a static "follow" card without it) ─────
INSTAGRAM_ACCESS_TOKEN=
