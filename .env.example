# ── Required ────────────────────────────────────────────────────────────────
# Admin login for /admin — the user is created automatically on first boot.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me-please

# Canonical URL used for SEO / sitemap / receipts (defaults to https://fitizens.in).
NEXT_PUBLIC_SITE_URL=https://fitizens.in

# ── Storage (optional) ──────────────────────────────────────────────────────
# Where the SQLite DB + uploaded images live. Defaults to ./data locally and
# /data inside Docker (mount a volume there!).
# DATA_DIR=./data

# ── Email (optional — enquiries/newsletters log to console until configured) ─
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Where enquiry notifications go. Defaults to the trainer email set in /admin.
LEAD_TO_EMAIL=

# ── Razorpay (consultation payment — the pay step degrades gracefully until set) ─
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Test-only: lets the booking flow skip payment when Razorpay isn't configured.
# Auto-on in local dev. Ignored in production; live deployments never allow bypass.
# ALLOW_PAYMENT_BYPASS=false

# Required in production: verifies Calendly scheduled-event URIs server-side
# before marking a paid booking as booked.
CALENDLY_ACCESS_TOKEN=

# ── Meta WhatsApp Cloud API (optional trainer booking notifications) ─────────
# Sends the trainer a WhatsApp template message after a paid consultation slot
# is booked. No-op when required values are unset.
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
# Recipient trainer number. Optional; falls back to trainer WhatsApp in /admin.
META_WHATSAPP_TO=
META_WHATSAPP_TEMPLATE_NAME=booking_confirmation_trainer
META_WHATSAPP_TEMPLATE_LANGUAGE=en_US
# Use the Graph API version shown in your Meta app dashboard if different.
META_GRAPH_API_VERSION=v23.0

# ── Analytics (optional) ────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# ── Instagram feed (optional — shows a static "follow" card without it) ─────
INSTAGRAM_ACCESS_TOKEN=
